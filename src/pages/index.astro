---
import Base from '../layouts/Base.astro'
---

<Base>
    <!-- ========== HERO ========== -->
    <section id="hero" class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 overflow-hidden">
      <!-- Background image -->
      <div class="absolute inset-0">
        <img src="/images/backflip.webp" alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-deep/80 via-deep/60 to-deep/90"></div>
      </div>
      <!-- Decorative radial glow -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-flame/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="relative z-10 max-w-5xl">
        <p class="font-display text-lg md:text-xl tracking-[0.3em] text-cyan-400 mb-2">21ST ANNUAL</p>
        <h1 class="font-display text-[clamp(5rem,15vw,14rem)] leading-[0.85] text-white mb-2 drop-shadow-[0_0_60px_rgba(34,211,238,0.15)]">
          THE SORTIE
        </h1>
        <p class="font-display text-[clamp(3rem,8vw,7rem)] leading-none text-shimmer mb-6">2026</p>
        <p class="text-slate-400 text-base md:text-lg tracking-widest uppercase mb-2">
          Hok-Si-La Park &bull; Lake City, MN
        </p>
        <p class="font-display text-2xl md:text-3xl text-gold tracking-wider mb-10">
          AUGUST 20 &ndash; 23
        </p>
        <a href="#join" class="inline-block px-10 py-4 bg-flame text-white font-display text-xl tracking-widest rounded-full hover:bg-sunset transition-colors">
          JOIN THE RIDE
        </a>
      </div>

      <!-- Wave divider -->
      <div class="absolute bottom-0 left-0 right-0 z-10 leading-[0]">
        <svg viewBox="0 0 1440 100" preserveAspectRatio="none" class="w-full h-[50px] md:h-[100px]">
          <path d="M0,60 C240,100 480,20 720,60 C960,100 1200,20 1440,60 L1440,100 L0,100 Z" fill="#0b1426" />
        </svg>
      </div>
    </section>

    <!-- ========== ABOUT ========== -->
    <section id="about" class="bg-navy relative py-24 md:py-32 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center mb-16">
          <!-- Text column -->
          <div class="reveal">
            <p class="font-display text-lg tracking-[0.2em] text-flame mb-3">WHAT IS THE SORTIE?</p>
            <h2 class="font-display text-4xl md:text-6xl text-white mb-6">THE MIDWEST'S PREMIER JET SKI WEEKEND</h2>
            <p class="text-slate-400 text-lg leading-relaxed mb-8">
              Every August, riders from across the country descend on the bluffs overlooking Lake Pepin for four days of riding, camping, and camaraderie. Whether you're a factory pro or just bought your first ski, the Sortie is where you belong.
            </p>
            <!-- Stats -->
            <div class="grid grid-cols-3 gap-4">
              <div class="reveal reveal-delay-1">
                <p class="font-display text-5xl md:text-6xl text-cyan-400 mb-1">21</p>
                <p class="text-slate-400 tracking-widest uppercase text-xs font-medium">Years Running</p>
              </div>
              <div class="reveal reveal-delay-2">
                <p class="font-display text-5xl md:text-6xl text-cyan-400 mb-1">100+</p>
                <p class="text-slate-400 tracking-widest uppercase text-xs font-medium">Riders Annually</p>
              </div>
              <div class="reveal reveal-delay-3">
                <p class="font-display text-5xl md:text-6xl text-cyan-400 mb-1">4</p>
                <p class="text-slate-400 tracking-widest uppercase text-xs font-medium">Days of Riding</p>
              </div>
            </div>
          </div>
          <!-- Image column -->
          <div class="reveal reveal-delay-1 rounded-2xl overflow-hidden">
            <img src="/images/beach-skis.webp" alt="Jet skis lined up on the beach at Lake Pepin" class="w-full h-auto object-cover" loading="lazy" />
          </div>
        </div>
      </div>

    </section>

    <!-- ========== EXPERIENCE ========== -->
    <section id="experience" class="relative bg-deep">
      <!-- Section title: normal flow on mobile, overlays images on md+ -->
      <div class="relative md:absolute md:top-0 md:left-0 md:right-0 z-20 text-center py-6 md:pt-24 md:pb-0 pointer-events-none">
        <h2 class="font-display text-4xl md:text-6xl text-white drop-shadow-[0_2px_20px_rgba(0,0,0,0.5)]">THIS IS THE SORTIE</h2>
      </div>
      <!-- Full-width 4-column row -->
      <div class="relative overflow-hidden">
        <!-- Wave clipping the top of the images -->
        <div class="absolute top-0 left-0 right-0 leading-[0] z-10">
          <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[40px] md:h-[80px]">
            <path d="M0,40 C360,80 720,10 1080,50 C1260,65 1380,30 1440,40 L1440,0 L0,0 Z" fill="#0b1426" />
          </svg>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 min-h-[100vh] md:min-h-[70vh]">
          <!-- Riding -->
          <div class="relative group overflow-hidden">
            <img src="/images/open-water-2.webp" alt="Open water riding on Lake Pepin" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/90 transition-all duration-500"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">OPEN WATER RIDING</h3>
              <p class="text-slate-100 text-sm md:text-base leading-relaxed font-light">
                Lake Pepin is your playground. Buoy courses, massive double-up sessions, freeride runs, and endless cruising.
              </p>
            </div>
          </div>

          <!-- Camping -->
          <div class="relative group overflow-hidden">
            <img src="/images/camping.webp" alt="Campsite at Hok-Si-La Park overlooking Lake Pepin" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/90 transition-all duration-500"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">BLUFFTOP CAMPING</h3>
              <p class="text-slate-100 text-sm md:text-base leading-relaxed font-light">
                Section B reserved on the bluff overlooking Lake Pepin. Fire rings, hot showers, $16/night. Just show up.
              </p>
            </div>
          </div>

          <!-- Feasts & Fires -->
          <div class="relative group overflow-hidden">
            <img src="/images/beach-skis.webp" alt="Jet skis lined up on the beach" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/90 transition-all duration-500"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">FEASTS & FIRES</h3>
              <p class="text-slate-100 text-sm md:text-base leading-relaxed font-light">
                Kiwanis breakfast Saturday morning. Pig roast Saturday night. Campfires and cold drinks every other night.
              </p>
            </div>
          </div>

          <!-- The Big Raffle -->
          <div class="relative group overflow-hidden">
            <img src="/images/superjet-water-2.webp" alt="Superjet carving on Lake Pepin" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/90 transition-all duration-500"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">THE BIG RAFFLE</h3>
              <p class="text-slate-100 text-sm md:text-base leading-relaxed font-light">
                Sponsors go all out — gear, parts, apparel, and at least one full jet ski raffled off Saturday night.
              </p>
            </div>
          </div>
        </div>

        <!-- Wave clipping the bottom of the images -->
        <div class="absolute bottom-0 left-0 right-0 leading-[0] z-10">
          <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[40px] md:h-[80px]">
            <path d="M0,40 C360,80 720,10 1080,50 C1260,65 1380,30 1440,40 L1440,80 L0,80 Z" fill="#050d1a" />
          </svg>
        </div>
      </div>
    </section>

    <!-- ========== SCHEDULE ========== -->
    <section id="schedule" class="bg-deep relative py-24 md:py-32 px-6">

      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="font-display text-lg tracking-[0.2em] text-flame mb-3">THE WEEKEND</p>
          <h2 class="font-display text-4xl md:text-6xl text-white">FOUR DAYS ON THE WATER</h2>
        </div>

        <!-- Timeline -->
        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-cyan-500/40 via-flame/40 to-gold/40"></div>

          <!-- Thursday -->
          <div class="reveal relative flex flex-col md:flex-row md:items-start mb-12 md:mb-16">
            <div class="md:w-1/2 md:text-right md:pr-12 pl-16 md:pl-0">
              <p class="font-display text-3xl text-cyan-400 tracking-wide">THURSDAY</p>
              <p class="text-lg text-white font-medium mb-1">August 20</p>
              <p class="text-slate-400">Roll in whenever you're ready. Set up camp, launch your ski, meet the crew. The water's already warm and the beer's already cold.</p>
            </div>
            <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-cyan-400 border-4 border-deep mt-1 md:mt-2"></div>
          </div>

          <!-- Friday -->
          <div class="reveal relative flex flex-col md:flex-row md:items-start mb-12 md:mb-16">
            <div class="md:w-1/2"></div>
            <div class="md:w-1/2 md:pl-12 pl-16">
              <p class="font-display text-3xl text-flame tracking-wide">FRIDAY</p>
              <p class="text-lg text-white font-medium mb-1">August 21</p>
              <p class="text-slate-400">Full day of open riding. The buoy course goes up. Freeride sessions all day. Evening campfire hangout with the whole crew.</p>
            </div>
            <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-flame border-4 border-deep mt-1 md:mt-2"></div>
          </div>

          <!-- Saturday -->
          <div class="reveal relative flex flex-col md:flex-row md:items-start mb-12 md:mb-16">
            <div class="md:w-1/2 md:text-right md:pr-12 pl-16 md:pl-0">
              <p class="font-display text-3xl text-sunset tracking-wide">SATURDAY</p>
              <p class="text-lg text-white font-medium mb-1">August 22 &mdash; The Main Event</p>
              <p class="text-slate-400">Kiwanis breakfast fuels the morning session. Ride all day. Pig roast dinner at sunset. Then the legendary raffle — someone's going home with a new ski.</p>
            </div>
            <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-sunset border-4 border-deep mt-1 md:mt-2"></div>
          </div>

          <!-- Sunday -->
          <div class="reveal relative flex flex-col md:flex-row md:items-start">
            <div class="md:w-1/2"></div>
            <div class="md:w-1/2 md:pl-12 pl-16">
              <p class="font-display text-3xl text-gold tracking-wide">SUNDAY</p>
              <p class="text-lg text-white font-medium mb-1">August 23</p>
              <p class="text-slate-400">Last rides of the weekend. Get out on the glass one more time before packing up. See you next year — or at the next group ride.</p>
            </div>
            <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-gold border-4 border-deep mt-1 md:mt-2"></div>
          </div>
        </div>
      </div>

      <!-- Wave divider -->
      <div class="absolute bottom-0 left-0 right-0 leading-[0]">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[40px] md:h-[80px]">
          <path d="M0,50 C320,10 640,70 960,30 C1120,10 1300,60 1440,40 L1440,80 L0,80 Z" fill="#0b1426" />
        </svg>
      </div>
    </section>

    <!-- ========== GALLERY ========== -->
    <section id="gallery" class="bg-navy relative py-24 md:py-32 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="font-display text-lg tracking-[0.2em] text-flame mb-3">PAST SORTIES</p>
          <h2 class="font-display text-4xl md:text-6xl text-white">MEMORIES FROM THE WATER</h2>
        </div>

        <!-- Photo/Video Grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
          <!-- Large feature — big air behind boat -->
          <div class="reveal col-span-2 row-span-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/big-air-behind-boat.webp"
              alt="Big air behind a boat on Lake Pepin"
              class="w-full h-full object-cover aspect-square md:aspect-auto md:h-full"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
              <p class="text-white font-display text-xl tracking-wide">BIG AIR</p>
            </div>
          </div>

          <!-- Rickter big air -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/rickter-big-air.webp"
              alt="Rickter getting big air"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">STANDUP LIFE</p>
            </div>
          </div>

          <!-- People hanging out -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/people-talking.webp"
              alt="Riders hanging out at camp"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">THE CREW</p>
            </div>
          </div>

          <!-- Many skis -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/many-skis.webp"
              alt="Many jet skis gathered at the Sortie"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">THE LINEUP</p>
            </div>
          </div>

          <!-- Superjet duo -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/superjet-duo.webp"
              alt="Two superjets riding together"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">RIDE TOGETHER</p>
            </div>
          </div>

          <!-- Family tubing -->
          <div class="reveal reveal-delay-3 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/family-tube.webp"
              alt="Family tubing on Lake Pepin"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">ALL AGES WELCOME</p>
            </div>
          </div>

          <!-- Backflip 2 -->
          <div class="reveal gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/backflip-2.webp"
              alt="Rider doing a backflip"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">SEND IT</p>
            </div>
          </div>

          <!-- Purple ski -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/purple-ski.webp"
              alt="Purple jet ski on the water"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">STYLE POINTS</p>
            </div>
          </div>

          <!-- Flip 7 -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/flip-7.webp"
              alt="Rider mid-flip on a jet ski"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">UPSIDE DOWN</p>
            </div>
          </div>

          <!-- Revolver -->
          <div class="reveal gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/revolver.webp"
              alt="Revolver ski on the water"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">REVOLVER</p>
            </div>
          </div>

          <!-- Superjet 3 -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/superjet-3.webp"
              alt="Superjet riding on the lake"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">SUPERJET</p>
            </div>
          </div>

          <!-- Flip 8 -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/flip-8.webp"
              alt="Rider doing a flip"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">FULL ROTATION</p>
            </div>
          </div>

          <!-- Wet bike -->
          <div class="reveal gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/wet-bike.webp"
              alt="Wet bike at the Sortie"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">WET BIKE</p>
            </div>
          </div>

          <!-- Beach skis -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/beach-skis.webp"
              alt="Jet skis on the beach"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">BEACH DAY</p>
            </div>
          </div>

          <!-- Rickter water -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/rickter-water.webp"
              alt="Rickter freestyle ski on the water"
              class="w-full h-full object-cover aspect-square"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">RICKTER</p>
            </div>
          </div>
        </div>

        <!-- Videos -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4 mt-3 md:mt-4">
          <div class="reveal rounded-2xl overflow-hidden">
            <video
              class="w-full h-auto"
              autoplay
              muted
              loop
              playsinline
              poster="/images/super-jet-water.webp"
            >
              <source src="/videos/superjet-cork.mp4" type="video/mp4" />
            </video>
          </div>
          <div class="reveal reveal-delay-1 rounded-2xl overflow-hidden">
            <video
              class="w-full h-auto"
              autoplay
              muted
              loop
              playsinline
              poster="/images/open-water.webp"
            >
              <source src="/videos/boat-riders.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>

      <!-- Wave divider -->
      <div class="absolute bottom-0 left-0 right-0 leading-[0]">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[40px] md:h-[80px]">
          <path d="M0,40 C480,80 960,0 1440,50 L1440,80 L0,80 Z" fill="#050d1a" />
        </svg>
      </div>
    </section>

    <!-- ========== MERCH ========== -->
    <section id="merch" class="bg-deep relative py-24 md:py-32 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="font-display text-lg tracking-[0.2em] text-flame mb-3">REPRESENT</p>
          <h2 class="font-display text-4xl md:text-6xl text-white">GEAR UP</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          <!-- Tee -->
          <div class="reveal reveal-delay-1 merch-card bg-midnight/40 border border-white/5 rounded-2xl overflow-hidden">
            <div class="aspect-square bg-gradient-to-br from-storm to-midnight flex items-center justify-center p-8">
              <div class="text-center">
