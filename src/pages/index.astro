---
import Base from '../layouts/Base.astro'
---

<Base>
    <!-- ========== HERO ========== -->
    <section id="hero" class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 overflow-hidden">
      <!-- Background image -->
      <div class="absolute inset-0">
        <img src="/images/backflip.webp" alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-deep/90 via-deep/75 to-deep/95"></div>
      </div>
      <!-- Decorative radial glow -->
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-blue-600/5 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-red-600/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="relative z-10 max-w-6xl w-full grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
        <!-- Logo column -->
        <div class="flex justify-center md:justify-end">
          <img src="/tcjp-sortie-2026-logo.png" alt="20th Annual TCJP Sortie 2026" class="w-[440px] md:w-[580px] lg:w-[700px] h-auto drop-shadow-[0_0_60px_rgba(0,51,160,0.6)]" />
        </div>
        <!-- Text column -->
        <div class="text-center md:text-left">
          <h1 class="font-display text-[clamp(5rem,12vw,12rem)] leading-[0.85] text-white mb-6 drop-shadow-[0_4px_20px_rgba(0,0,0,0.6)]">
            THE SORTIE
          </h1>
          <p class="text-slate-300 text-lg md:text-xl leading-relaxed max-w-lg mb-8 drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)]">
            Join us August 27&ndash;30 at Hok-Si-La Park in Lake City, Minnesota for the 20th annual Sortie. Four days of riding, camping, and bonfires on Lake Pepin.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="https://www.facebook.com/events/2507939626270296/?acontext=%7B%22event_action_history%22%3A[%7B%22surface%22%3A%22group%22%7D]%7D"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-10 py-4 bg-[#cc0000] text-white font-display text-xl tracking-widest rounded-full hover:bg-[#e60000] transition-colors"
            >
              RSVP NOW
            </a>
            <a
              href="https://www.facebook.com/groups/tcjetpilots"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-10 py-4 border border-white/20 text-white font-display text-xl tracking-widest rounded-full hover:bg-white/10 transition-colors"
            >
              JOIN ON FACEBOOK
            </a>
          </div>
        </div>
      </div>

      <!-- Wave divider -->
      <div class="absolute bottom-0 left-0 right-0 z-10 leading-[0]">
        <svg viewBox="0 0 1440 100" preserveAspectRatio="none" class="w-full h-[50px] md:h-[100px]">
          <path d="M0,60 C240,100 480,20 720,60 C960,100 1200,20 1440,60 L1440,100 L0,100 Z" fill="#0c0c1a" />
        </svg>
      </div>
    </section>

    <!-- ========== ABOUT THE SORTIE ========== -->
    <section id="about" class="bg-navy relative py-24 md:py-32 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
          <!-- Image column -->
          <div class="reveal rounded-2xl overflow-hidden">
            <img src="/images/beach-skis.webp" alt="Jet skis lined up on the beach at Lake Pepin" class="w-full h-auto object-cover" loading="lazy" />
          </div>
          <!-- Text column -->
          <div class="reveal reveal-delay-1">
            <p class="font-display text-lg tracking-[0.2em] text-red-500 mb-3">WHAT IS THE SORTIE?</p>
            <h2 class="font-display text-4xl md:text-6xl text-white mb-6">THE MIDWEST'S BIGGEST JET SKI WEEKEND</h2>
            <p class="text-slate-400 text-lg leading-relaxed mb-8">
              The Sortie has been happening every August for twenty years. More than a hundred riders and their families come out to Hok-Si-La Park on Lake Pepin for four days of riding, camping, and one of the best weekends of the summer. Everyone is welcome.
            </p>
            <div class="grid grid-cols-3 gap-4">
              <div class="reveal reveal-delay-2">
                <p class="font-display text-5xl md:text-6xl text-blue-500 mb-1">20</p>
                <p class="text-slate-400 tracking-widest uppercase text-xs font-medium">Years Running</p>
              </div>
              <div class="reveal reveal-delay-3">
                <p class="font-display text-5xl md:text-6xl text-red-500 mb-1">100+</p>
                <p class="text-slate-400 tracking-widest uppercase text-xs font-medium">Riders Annually</p>
              </div>
              <div class="reveal reveal-delay-4">
                <p class="font-display text-5xl md:text-6xl text-blue-500 mb-1">4</p>
                <p class="text-slate-400 tracking-widest uppercase text-xs font-medium">Days of Riding</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== EXPERIENCE ========== -->
    <section id="experience" class="relative bg-deep">
      <!-- Full-width 4-column row -->
      <div class="relative overflow-hidden">
        <!-- Wave clipping the top of the images -->
        <div class="absolute top-0 left-0 right-0 leading-[0] z-10">
          <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[40px] md:h-[80px]">
            <path d="M0,40 C360,80 720,10 1080,50 C1260,65 1380,30 1440,40 L1440,0 L0,0 Z" fill="#0c0c1a" />
          </svg>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 min-h-[100vh] md:min-h-[70vh]">
          <!-- Riding -->
          <div class="relative group overflow-hidden">
            <img src="/images/open-water-2.webp" alt="Open water riding on Lake Pepin" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">OPEN WATER RIDING</h3>
              <p class="text-white text-sm md:text-base leading-relaxed drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">
                Lake Pepin is one of the widest stretches of the Mississippi, so there is plenty of open water to ride. Expect the buoy course running most days, double-ups behind the boat, and miles of freeride.
              </p>
            </div>
          </div>

          <!-- Camping -->
          <div class="relative group overflow-hidden">
            <img src="/images/camping.webp" alt="Campsite at Hok-Si-La Park overlooking Lake Pepin" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">BLUFFTOP CAMPING</h3>
              <p class="text-white text-sm md:text-base leading-relaxed drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">
                Section B is reserved for the Sortie crew, on the bluff above the lake. Campsites have fire rings with cooking grates and free firewood, and the showers are a short walk away. Sites are $30 per person per night, paid at the park office when you check in.
              </p>
            </div>
          </div>

          <!-- Feasts & Fires -->
          <div class="relative group overflow-hidden">
            <img src="/images/beach-skis.webp" alt="Jet skis lined up on the beach" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">FEASTS & FIRES</h3>
              <p class="text-white text-sm md:text-base leading-relaxed drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">
                The local Lions Club is handling meals for the weekend. Full menu details are coming soon. Free firewood is available all weekend, so campfires run late at every site.
              </p>
            </div>
          </div>

          <!-- The Big Raffle -->
          <div class="relative group overflow-hidden">
            <img src="/images/raffle.webp" alt="The Sortie jet ski raffle" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10"></div>
            <div class="relative z-10 h-full flex flex-col justify-end p-5 md:p-8 pb-14 md:pb-20">
              <h3 class="font-display text-2xl md:text-3xl text-white mb-2 tracking-wide">THE BIG RAFFLE</h3>
              <p class="text-white text-sm md:text-base leading-relaxed drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">
                Every year we raffle off a jet ski. Tickets are $20, available all weekend, and the winner is drawn Saturday night after dinner. You have to be present to take it home, so don't head out early.
              </p>
            </div>
          </div>
        </div>

        <!-- Wave clipping the bottom of the images -->
        <div class="absolute bottom-0 left-0 right-0 leading-[0] z-10">
          <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-[40px] md:h-[80px]">
            <path d="M0,40 C360,80 720,10 1080,50 C1260,65 1380,30 1440,40 L1440,80 L0,80 Z" fill="#080810" />
          </svg>
        </div>
      </div>
    </section>

    <!-- ========== SCHEDULE ========== -->
    <section id="schedule">
      <div class="bg-deep py-24 md:py-32 text-center px-6">
        <div class="reveal">
          <p class="font-display text-lg tracking-[0.2em] text-red-500 mb-3">THE WEEKEND</p>
          <h2 class="font-display text-4xl md:text-6xl text-white">FOUR DAYS ON THE WATER</h2>
        </div>
      </div>

      <!-- Thursday — image left, text right -->
      <div class="min-h-screen grid grid-cols-1 md:grid-cols-2">
        <div class="relative overflow-hidden">
          <img src="/images/camping.webp" alt="Campsite at Hok-Si-La Park" class="w-full h-full object-cover min-h-[50vh] md:min-h-screen" loading="lazy" />
        </div>
        <div class="flex items-center bg-deep px-8 md:px-16 lg:px-24 py-16 md:py-0">
          <div class="reveal">
            <p class="font-display text-lg tracking-[0.3em] text-blue-400 mb-3">DAY ONE</p>
            <h2 class="font-display text-6xl md:text-7xl lg:text-8xl text-white mb-4 leading-[0.85]">THURSDAY</h2>
            <p class="font-display text-2xl text-red-500 tracking-wider mb-6">AUGUST 27</p>
            <p class="text-slate-400 text-lg leading-relaxed max-w-lg">
              Thursday is arrival day. People show up all afternoon and evening. Section B fills up in the order people arrive, so the earlier you get there, the better your pick of campsites and shoreline spots for beaching your ski. Get camp set up, get your ski in the water, and catch up with everyone you haven't seen since last August.
            </p>
          </div>
        </div>
      </div>

      <!-- Friday — text left, image right -->
      <div class="min-h-screen grid grid-cols-1 md:grid-cols-2">
        <div class="flex items-center justify-end bg-navy px-8 md:px-16 lg:px-24 py-16 md:py-0 order-2 md:order-1">
          <div class="reveal">
            <p class="font-display text-lg tracking-[0.3em] text-red-500 mb-3">DAY TWO</p>
            <h2 class="font-display text-6xl md:text-7xl lg:text-8xl text-white mb-4 leading-[0.85]">FRIDAY</h2>
            <p class="font-display text-2xl text-blue-400 tracking-wider mb-6">AUGUST 28</p>
            <p class="text-slate-400 text-lg leading-relaxed max-w-lg">
              Friday is the first full day on the water. The buoy course is set up by mid-morning and freeride runs until dusk.
            </p>
          </div>
        </div>
        <div class="relative overflow-hidden order-1 md:order-2">
          <img src="/images/open-water-2.webp" alt="Open water riding on Lake Pepin" class="w-full h-full object-cover min-h-[50vh] md:min-h-screen" loading="lazy" />
        </div>
      </div>

      <!-- Saturday — image left, text right -->
      <div class="min-h-screen grid grid-cols-1 md:grid-cols-2">
        <div class="relative overflow-hidden">
          <img src="/images/big-air-behind-boat.webp" alt="Big air behind a boat on Lake Pepin" class="w-full h-full object-cover min-h-[50vh] md:min-h-screen" loading="lazy" />
        </div>
        <div class="flex items-center bg-deep px-8 md:px-16 lg:px-24 py-16 md:py-0">
          <div class="reveal">
            <p class="font-display text-lg tracking-[0.3em] text-white mb-3">DAY THREE</p>
            <h2 class="font-display text-6xl md:text-7xl lg:text-8xl text-white mb-4 leading-[0.85]">SATURDAY</h2>
            <p class="font-display text-2xl text-red-500 tracking-wider mb-6">AUGUST 29 // THE MAIN EVENT</p>
            <p class="text-slate-400 text-lg leading-relaxed max-w-lg">
              Saturday is the main event and the biggest turnout of the weekend. Riding and the buoy course run all day. The Lions Club is serving dinner, and the jet ski raffle is right after. Tickets are $20 and you have to be present to win.
            </p>
          </div>
        </div>
      </div>

      <!-- Sunday — text left, image right -->
      <div class="min-h-screen grid grid-cols-1 md:grid-cols-2">
        <div class="flex items-center justify-end bg-navy px-8 md:px-16 lg:px-24 py-16 md:py-0 order-2 md:order-1">
          <div class="reveal">
            <p class="font-display text-lg tracking-[0.3em] text-blue-400 mb-3">DAY FOUR</p>
            <h2 class="font-display text-6xl md:text-7xl lg:text-8xl text-white mb-4 leading-[0.85]">SUNDAY</h2>
            <p class="font-display text-2xl text-red-500 tracking-wider mb-6">AUGUST 30</p>
            <p class="text-slate-400 text-lg leading-relaxed max-w-lg">
              Sunday is for one last session on the water. It's usually glass in the morning, the crew is smaller, and the riding is some of the best of the weekend. Pack up camp after lunch and head home.
            </p>
          </div>
        </div>
        <div class="relative overflow-hidden order-1 md:order-2">
          <img src="/images/superjet-water-2.webp" alt="Superjet on Lake Pepin" class="w-full h-full object-cover min-h-[50vh] md:min-h-screen" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ========== GALLERY ========== -->
    <section id="gallery" class="bg-navy relative py-24 md:py-32 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal">
          <p class="font-display text-lg tracking-[0.2em] text-red-500 mb-3">PAST SORTIES</p>
          <h2 class="font-display text-4xl md:text-6xl text-white">MEMORIES FROM THE WATER</h2>
        </div>

        <!-- Photo/Video Grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
          <!-- Large feature — big air behind boat -->
          <div class="reveal col-span-2 row-span-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/big-air-behind-boat.webp"
              alt="Big air behind a boat on Lake Pepin"
              class="w-full h-full object-cover aspect-square md:aspect-auto md:h-full"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
              <p class="text-white font-display text-xl tracking-wide">BIG AIR</p>
            </div>
          </div>

          <!-- Rickter big air -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/rickter-big-air.webp"
              alt="Rickter getting big air"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">STANDUP LIFE</p>
            </div>
          </div>

          <!-- People hanging out -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/people-talking.webp"
              alt="Riders hanging out at camp"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">THE CREW</p>
            </div>
          </div>

          <!-- Many skis -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/many-skis.webp"
              alt="Many jet skis gathered at the Sortie"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">THE LINEUP</p>
            </div>
          </div>

          <!-- Superjet duo -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/superjet-duo.webp"
              alt="Two superjets riding together"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">RIDE TOGETHER</p>
            </div>
          </div>

          <!-- Family tubing -->
          <div class="reveal reveal-delay-3 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/family-tube.webp"
              alt="Family tubing on Lake Pepin"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">ALL AGES WELCOME</p>
            </div>
          </div>

          <!-- Backflip 2 -->
          <div class="reveal gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/backflip-2.webp"
              alt="Rider doing a backflip"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">SEND IT</p>
            </div>
          </div>

          <!-- Purple ski -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/purple-ski.webp"
              alt="Purple jet ski on the water"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">STYLE POINTS</p>
            </div>
          </div>

          <!-- Flip 7 -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/flip-7.webp"
              alt="Rider mid-flip on a jet ski"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">UPSIDE DOWN</p>
            </div>
          </div>

          <!-- Revolver -->
          <div class="reveal gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/revolver.webp"
              alt="Revolver ski on the water"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">REVOLVER</p>
            </div>
          </div>

          <!-- Superjet 3 -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/superjet-3.webp"
              alt="Superjet riding on the lake"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">SUPERJET</p>
            </div>
          </div>

          <!-- Flip 8 -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/flip-8.webp"
              alt="Rider doing a flip"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">FULL ROTATION</p>
            </div>
          </div>

          <!-- Wet bike -->
          <div class="reveal gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/wet-bike.webp"
              alt="Wet bike at the Sortie"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">WET BIKE</p>
            </div>
          </div>

          <!-- Beach skis -->
          <div class="reveal reveal-delay-1 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/beach-skis.webp"
              alt="Jet skis on the beach"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">BEACH DAY</p>
            </div>
          </div>

          <!-- Rickter water -->
          <div class="reveal reveal-delay-2 gallery-item rounded-2xl overflow-hidden relative group">
            <img
              src="/images/rickter-water.webp"
              alt="Rickter freestyle ski on the water"
              class="w-full h-full object-cover aspect-square"
                         />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white font-display tracking-wide">RICKTER</p>
            </div>
          </div>
        </div>

        <!-- Lightbox -->
        <div id="gallery-lightbox" class="lightbox-overlay">
          <button id="lightbox-close" class="lightbox-close" aria-label="Close lightbox">&times;</button>
          <div class="swiper lightbox-swiper">
            <div class="swiper-wrapper" id="lightbox-slides"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div>
            <div class="swiper-pagination"></div>
          </div>
        </div>

        <!-- Videos -->
